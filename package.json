{
  "name": "@customrflow/print-agent",
  "version": "0.1.0",
  "description": "Customrflow Print Agent — connects to the Customrflow SaaS and drives ESC/POS, Star-Line and CUPS printers on a local restaurant network.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hqapps777/customrflow-print-agent.git"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "xflow-print-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --files src/index.ts",
    "test": "jest",
    "package": "pkg . --out-path bin"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@point-of-sale/receipt-printer-encoder": "^3.0.3",
    "bonjour-service": "^1.2.1",
    "fastify": "^4.28.1",
    "ipp": "^2.0.1",
    "pino": "^9.3.2",
    "socket.io-client": "^4.8.0",
    "yaml": "^2.5.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.5.0",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "pkg": {
    "assets": [
      "src/web-ui/static/**/*"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ]
  }
}
